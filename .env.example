# ── Zerodha Kite Connect ────────────────────────────────────────────
# Get API key + secret from kite.trade/developers (one-time setup)
# Access token expires daily at 6 AM — copy a fresh one each morning
# from Kite Console → Account → API
KITE_API_KEY=your_kite_api_key
KITE_ACCESS_TOKEN=your_daily_access_token

# ── Groww Trade API ─────────────────────────────────────────────────
# Docs: https://groww.in/trade-api/docs/curl/portfolio
# Get API key + secret from Groww → Profile → Trade API → Cloud API Keys
# Run scripts/generate_groww_token.py each morning to refresh the access token
GROWW_API_KEY=your_groww_api_key
GROWW_API_SECRET=your_groww_api_secret
GROWW_ACCESS_TOKEN=your_groww_daily_token

# ── Output ──────────────────────────────────────────────────────────
DB_PATH=data/output/asset_dashboard.db
CSV_OUTPUT_DIR=data/output

# ── Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Tuning ──────────────────────────────────────────────────────────
YFINANCE_MAX_WORKERS=4
